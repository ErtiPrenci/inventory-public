# Copy this file to .env and fill in your values
# NEVER commit the .env file — it is in .gitignore

# PostgreSQL connection string (e.g. Supabase, RDS, local)
DATABASE_URL="postgres://user:password@host:5432/dbname?default_query_exec_mode=simple_protocol"

# "local" for development, "prod" for production
ENVIRONMENT=local

# HS256 JWT signing secret — use a long random string in production
JWT_SECRET=your-super-secret-jwt-key-here

# Name shown in generated PDF documents
COMPANY_NAME="Tu Empresa"

# AWS S3 bucket name for invoice storage
S3_BUCKET_NAME="nombre-de-tu-bucket"

# Allowed CORS origin for the frontend (leave empty to allow all origins in local dev)
FRONTEND_URL=""

# Set this to any non-empty value when running inside AWS Lambda
LAMBDA_FUNCTION_NAME=""

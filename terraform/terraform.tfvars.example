# Copy this file to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars — it is in .gitignore

# PostgreSQL connection string
db_url = "postgres://user:password@host:5432/dbname?default_query_exec_mode=simple_protocol"

# HS256 JWT signing secret (must match what your API uses)
jwt_secret = "your-super-secret-jwt-key-here"

# Deployment environment
environment = "prod"

# Company name shown in PDF invoices/quotes
company_name = "Tu Empresa"

# Domain Configuration
domain_name = "example.com"
subdomain   = "api.example.com"
